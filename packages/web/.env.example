# Supabase Configuration
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Google OAuth is configured in the Supabase dashboard:
# Authentication > Providers > Google
# Add your Google Client ID and Secret there.
# Set the redirect URL in Google Cloud Console to:
# https://your-project.supabase.co/auth/v1/callback

# Jitsi Voice Chat
# Domain of the Jitsi Meet server used for proximity voice chat.
# Defaults to the public meet.jit.si instance if not set.
# For production use, self-host a Jitsi server and set this to your domain.
# See https://jitsi.github.io/handbook/docs/devops-guide/devops-guide-quickstart
VITE_JITSI_DOMAIN=meet.jit.si
