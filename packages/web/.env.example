# Supabase Configuration
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Google OAuth is configured in the Supabase dashboard:
# Authentication > Providers > Google
# Add your Google Client ID and Secret there.
# Set the redirect URL in Google Cloud Console to:
# https://your-project.supabase.co/auth/v1/callback

# JaaS (Jitsi as a Service) Voice Chat — https://jaas.8x8.vc
# Sign up at https://jaas.8x8.vc to get your App ID and generate a JWT.
# VITE_JAAS_APP_ID  — found in the JaaS console under "API Keys" (format: vpaas-magic-cookie-...)
# VITE_JAAS_JWT     — a signed JWT; generate one in the JaaS console or via the REST API.
#                     For development you can use a long-lived token; for production generate
#                     short-lived tokens server-side and pass them in at runtime.
VITE_JAAS_APP_ID=vpaas-magic-cookie-your-app-id
VITE_JAAS_JWT=your-jaas-jwt-token
