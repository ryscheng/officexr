# Supabase Configuration
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Google OAuth is configured in the Supabase dashboard:
# Authentication > Providers > Google
# Add your Google Client ID and Secret there.
# Set the redirect URL in Google Cloud Console to:
# https://your-project.supabase.co/auth/v1/callback

# JaaS (Jitsi as a Service) Voice Chat — https://jaas.8x8.vc
# Sign up at https://jaas.8x8.vc, create an app, then add an API key under "API Keys".
# The app generates RS256-signed JWTs client-side with a 1-week TTL using these values.
#
# VITE_JAAS_APP_ID      — your App ID (format: vpaas-magic-cookie-…), shown on the dashboard
# VITE_JAAS_API_KEY_ID  — the Key ID shown next to the API key you created
# VITE_JAAS_PRIVATE_KEY — the RSA private key downloaded when you created the API key.
#                         Paste the full PEM block using \n for newlines, wrapped in quotes:
#                         "-----BEGIN PRIVATE KEY-----\nMIIEvAIBADA…\n-----END PRIVATE KEY-----"
VITE_JAAS_APP_ID=vpaas-magic-cookie-your-app-id
VITE_JAAS_API_KEY_ID=your-api-key-id
VITE_JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkqhkiG9w0BAQEFAASC...\n-----END PRIVATE KEY-----"
