{
  "name": "officexr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint",
    "build:web": "tsc -b && vite build",
    "build:desktop": "npm run build:web && npm run build --workspace=packages/desktop",
    "dist:desktop:mac": "npm run build:web && npm run dist:mac --workspace=packages/desktop",
    "dist:desktop:win": "npm run build:web && npm run dist:win --workspace=packages/desktop",
    "dist:desktop:linux": "npm run build:web && npm run dist:linux --workspace=packages/desktop",
    "dist:desktop:all": "npm run build:web && npm run dist:all --workspace=packages/desktop",
    "dev:mobile": "npm run start --workspace=packages/mobile",
    "build:mobile:ios": "npm run build:ios --workspace=packages/mobile",
    "build:mobile:android": "npm run build:android --workspace=packages/mobile"
  },
  "dependencies": {
    "@jitsi/react-sdk": "^1.4.4",
    "@officexr/core": "*",
    "@supabase/supabase-js": "^2.49.4",
    "@types/three": "^0.182.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.5.1",
    "three": "^0.182.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.3.2"
  }
}
